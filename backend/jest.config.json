{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "testMatch": ["**/__tests__/**/*.test.ts"],
  "moduleNameMapper": {
    "^algosdk$": "<rootDir>/node_modules/algosdk"
  },
  "transform": {
    "^.+\\.tsx?$": ["ts-jest", {
      "tsconfig": {
        "module": "commonjs",
        "esModuleInterop": true
      }
    }]
  }
}
