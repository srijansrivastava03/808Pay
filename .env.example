# 808Pay Environment Configuration Example
# Copy this to .env and fill in your values

# ============================================
# BACKEND SERVER
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# ALGORAND CONFIGURATION
# ============================================

# Option 1: Local AlgoKit (for development)
ALGORAND_SERVER=http://algokit:4001
ALGORAND_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGORAND_NETWORK=localnet

# Option 2: Testnet (Uncomment for testnet)
# ALGORAND_SERVER=https://testnet-algorand.api.purestake.io/ps2
# ALGORAND_TOKEN=your-purestake-api-token
# ALGORAND_NETWORK=testnet

# Option 3: Alchemy (Alternative provider)
# ALGORAND_SERVER=https://algorithms-testnet.g.alchemy.com/v2/your-api-key
# ALGORAND_TOKEN=your-alchemy-token
# ALGORAND_NETWORK=testnet

# ============================================
# SMART CONTRACT
# ============================================

# App ID of deployed smart contract (leave empty until deployed)
CONTRACT_APP_ID=

# Payment processor wallet address (your backend wallet)
PAYMENT_PROCESSOR_ADDRESS=

# ============================================
# PERA WALLET
# ============================================

# Pera Wallet Connect ID (get from pera developer dashboard)
PERA_WALLET_CONNECT_ID=

# ============================================
# FLUTTER FRONTEND
# ============================================

# Backend API endpoint (for mobile app)
API_BASE_URL=http://localhost:3000

# Enable debug mode
FLUTTER_DEBUG=true

# ============================================
# SECURITY
# ============================================

# JWT Secret (for future authentication)
# JWT_SECRET=your-secret-key-here

# API Rate Limiting
# RATE_LIMIT_WINDOW=60000  # 1 minute
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# DOCKER SPECIFIC
# ============================================

# Docker Compose environment
COMPOSE_PROJECT_NAME=808pay

# Log level
LOG_LEVEL=debug

# ============================================
# DATABASE (Future)
# ============================================

# DATABASE_URL=postgresql://user:password@localhost:5432/808pay
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_CONNECTIONS=20

# ============================================
# CACHE (Future)
# ============================================

# REDIS_URL=redis://localhost:6379
# CACHE_TTL=3600

# ============================================
# MONITORING (Future)
# ============================================

# SENTRY_DSN=https://your-sentry-dsn
# DATADOG_API_KEY=your-datadog-key

# ============================================
# Feature Flags
# ============================================

# Enable blockchain settlement
ENABLE_BLOCKCHAIN_SETTLEMENT=true

# Enable offline payments
ENABLE_OFFLINE_PAYMENTS=true

# Enable loyalty points
ENABLE_LOYALTY_POINTS=true

# Minimum payment amount (in cents)
MIN_PAYMENT_AMOUNT=100

# Maximum payment amount (in cents)
MAX_PAYMENT_AMOUNT=100000
